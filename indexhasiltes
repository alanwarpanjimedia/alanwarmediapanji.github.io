function cekData(){

let input=document.getElementById("nama").value.trim().toLowerCase();

let hasil=document.getElementById("hasil");

let pesan=document.getElementById("pesan");

let data=santri.find(s=>s.nama.toLowerCase().includes(input));

if(data){

hasil.style.display="block";

pesan.innerHTML="";

document.getElementById("namaSantri").innerHTML=data.nama;

document.getElementById("nilaiSantri").innerHTML=data.nilai;

if(data.keterangan=="LULUS"){

document.getElementById("keterangan").innerHTML=
'<span class="badge lulus">LULUS</span>';

}else{

document.getElementById("keterangan").innerHTML=
'<span class="badge tahfidz">LULUS TAHFIDZ</span>';

}

let isi="";

let no=1;

santri.forEach(function(item){

if(item.keterangan.includes("LULUS")){

isi+=`

<tr>

<td>${no++}</td>

<td>${item.nama}</td>

<td>${item.nilai}</td>

<td>${item.keterangan}</td>

</tr>

`;

}

});

document.getElementById("tabelLulus").innerHTML=isi;

}else{

hasil.style.display="none";

pesan.innerHTML="Nama santri tidak ditemukan.";

}

}

